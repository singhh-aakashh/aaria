<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- App bar -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/aaria_on_background"
            android:letterSpacing="0.02"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hands-free WhatsApp assistant"
            android:textSize="14sp"
            android:textColor="@color/aaria_on_surface_variant"
            android:paddingBottom="20dp" />

        <!-- Card: Access & battery -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/aaria_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/aaria_outline_variant"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Access"
                    android:textSize="13sp"
                    android:textColor="@color/aaria_on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/statusTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textColor="@color/aaria_on_surface"
                        android:text="@string/notification_access_status_disabled" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/enableListenerButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/notification_access_button"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/aaria_outline_variant"
                    android:layout_marginVertical="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/batteryStatusTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textColor="@color/aaria_on_surface"
                        android:text="@string/battery_opt_restricted" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/batteryOptButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/battery_opt_button"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Voice output -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/aaria_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/aaria_outline_variant"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tts_section_title"
                    android:textSize="13sp"
                    android:textColor="@color/aaria_on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/ssmlStatusTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/aaria_on_surface"
                    android:text="@string/ssml_status_unknown"
                    android:paddingBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testTtsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/test_tts_button"
                    android:textSize="13sp"
                    app:cornerRadius="20dp"
                    app:strokeColor="@color/aaria_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Mode -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/aaria_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/aaria_outline_variant"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_section_title"
                    android:textSize="13sp"
                    android:textColor="@color/aaria_on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingBottom="12dp" />

                <RadioGroup
                    android:id="@+id/modeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/modeNormal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/mode_normal"
                        android:textColor="@color/aaria_on_surface" />

                    <RadioButton
                        android:id="@+id/modeDriving"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/mode_driving"
                        android:textColor="@color/aaria_on_surface" />

                    <RadioButton
                        android:id="@+id/modeSilent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/mode_silent"
                        android:textColor="@color/aaria_on_surface" />
                </RadioGroup>

                <TextView
                    android:id="@+id/modeHintTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="@color/aaria_on_surface_variant"
                    android:text="@string/mode_driving_hint" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/markAsReadAfterTtsSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/mark_as_read_after_tts_label"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/aaria_on_surface"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Voice reply status -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/aaria_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/aaria_outline_variant"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="18dp">

                <ProgressBar
                    android:id="@+id/recordingIndicator"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:indeterminateTint="@color/aaria_primary"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_reply_section_title"
                        android:textSize="13sp"
                        android:textColor="@color/aaria_on_surface_variant"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/recordingStatusTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textColor="@color/aaria_on_surface"
                        android:text="@string/voice_reply_status_idle" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Message log -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/aaria_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/aaria_outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/logTitleTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/captured_messages_title"
                    android:textSize="13sp"
                    android:textColor="@color/aaria_on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingBottom="10dp" />

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/logScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="280dp"
                    android:fillViewport="false"
                    android:scrollbars="vertical">

                    <TextView
                        android:id="@+id/logTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/aaria_on_surface"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.25"
                        android:text="@string/no_messages_yet" />
                </androidx.core.widget.NestedScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
